---
import { getCollection } from 'astro:content';
const novels = await getCollection('novel');
---

<!DOCTYPE html>
<html lang="en" class="dark" data-color-scheme="dark" style="color-scheme: dark;">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width">
  <title>WTR-LAB - Novel Library</title>
  <link rel="stylesheet" href="/assets/css/style-01.css">
  <link rel="stylesheet" href="/assets/css/style-02.css">
  <link rel="stylesheet" href="/assets/css/style-03.css">
  <link rel="stylesheet" href="/assets/css/body-style-07.css">
</head>
<body class="wtr-adblock-off" style="background: #1b1d23; color: #e5e7eb; min-height: 100vh;">
  <div style="max-width: 800px; margin: 0 auto; padding: 3rem 1rem;">
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1rem;">WTR-LAB Novel Library</h1>
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      {novels.map(novel => (
        <a href={`/novel/${novel.slug}`} style="display: flex; gap: 1rem; padding: 1rem; border: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem; text-decoration: none; color: inherit; background: #1f2129; transition: background 0.2s;">
          {novel.data.cover && (
            <img src={novel.data.cover} alt="" style="width: 60px; height: 84px; object-fit: cover; border-radius: 4px; flex-shrink: 0;">
          )}
          <div>
            <h2 style="font-size: 1rem; font-weight: 600; margin: 0 0 0.25rem;">{novel.data.title}</h2>
            {novel.data.chineseTitle && <p style="margin: 0 0 0.5rem; font-size: 0.8rem; opacity: 0.7;">{novel.data.chineseTitle}</p>}
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              {novel.data.tags?.slice(0, 3).map(tag => (
                <span style="font-size: 0.7rem; padding: 0.15rem 0.5rem; border-radius: 999px; background: rgba(59,130,246,0.2); color: #60a5fa;">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</body>
</html>
