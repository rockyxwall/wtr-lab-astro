---
import Nav from '../components/Nav.astro'
import SvgSprite from '../components/SvgSprite.astro'
import SvgDefs from '../components/SvgDefs.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title?: string
  ogImage?: string
  ogType?: string
}

const {
  title = 'WTR-LAB',
  ogImage = '',
  ogType = 'website',
} = Astro.props
---

<html lang="en" class="dark" data-color-scheme="dark" style="color-scheme: dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com/" />
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Nunito+Sans:ital,wght@0,200..1000;1,200..1000&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="https://wtr-lab.com/assets/favicon_dark/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="https://wtr-lab.com/assets/favicon/favicon-dark.svg" />
    <link rel="shortcut icon" href="https://wtr-lab.com/assets/favicon_dark/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="https://wtr-lab.com/assets/favicon_dark/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="wtr-lab" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:type" content={ogType} />
  </head>
  <body class="wtr-adblock-off bg-background text-foreground font-sans antialiased">
    <SvgSprite />
    <SvgDefs />

    <Nav />

    <slot />

    <Footer />
  </body>
</html>

<script>
  (function() {
    try {
      const theme = localStorage.getItem('theme') || 'dark'
      const isDark = theme === 'dark'
      document.documentElement.classList.toggle('dark', isDark)
      document.documentElement.setAttribute('data-color-scheme', theme)
      document.documentElement.style.colorScheme = theme
    } catch (e) {}
  })()
</script>
