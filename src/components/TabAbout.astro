---
import type { InferEntrySchema } from 'astro:content';

interface Patron {
  name: string;
  amount: number;
  rank?: number;
}

interface OtherNovel {
  title: string;
  url: string;
}

interface Props {
  details?: InferEntrySchema<'novel'>['details'];
  rankings?: InferEntrySchema<'novel'>['rankings'];
  patrons?: Patron[];
  otherNovels?: OtherNovel[];
  slug?: string;
  tags?: string[];
  genres?: string[];
  tagCategories?: Record<string, string[]>;
  title?: string;
  chineseTitle?: string;
}

const {
  details,
  rankings,
  patrons = [],
  otherNovels = [],
  slug = "",
  tags = [],
  genres = [],
  tagCategories = {},
  title = "",
  chineseTitle = "",
} = Astro.props;
---

<div role="tabpanel" tabindex="0" data-index="0" data-slot="tabs-content" data-active data-orientation="horizontal" data-activation-direction="left">
  <section aria-labelledby="summary-heading">
    <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
      <span id="summary-heading" class="flex-1 text-base font-semibold text-card-foreground">Novel Summary</span>
    </div>
    <div class="desc-wrap text-foreground">
      <span class="description">
        <slot name="content" />
      </span>
      <div class="flex items-center justify-between mb-2">
        <div class="swap">Show more</div>
      </div>
      <span></span>
    </div>
  </section>

  {(genres.length > 0 || Object.keys(tagCategories).length > 0) && (
    <section aria-labelledby="genre-tags-heading">
      <h2 id="genre-tags-heading" class="flex items-center gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary text-base font-semibold text-card-foreground">
        Genre &amp; Tags
      </h2>
      <div class="rounded-lg border border-border overflow-hidden mb-4">
        {genres.length > 0 && (
          <div class="flex flex-wrap items-center gap-1.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022]">
            <div class="flex items-center w-full gap-1.5 text-[10px] uppercase tracking-wider font-bold text-muted-foreground">
              <span>Genre</span>
              <span class="text-[9px] font-normal text-muted-foreground/60">{genres.length}</span>
            </div>
            {genres.map((g, i) => (
              <span class="inline-flex items-center capitalize text-xs font-medium border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground">{g}</span>
            ))}
          </div>
        )}
        {Object.entries(tagCategories).map(([category, items], i) => (
          <div class="flex flex-wrap items-center gap-1.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022]">
            <div class="flex items-center w-full gap-1.5 text-[10px] uppercase tracking-wider font-bold text-muted-foreground">
              <span>{category}</span>
              <span class="text-[9px] font-normal text-muted-foreground/60">{items.length}</span>
            </div>
            {items.map((item: string) => (
              <span class="inline-flex items-center capitalize text-xs font-medium border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground hover:bg-muted/50 hover:text-card-foreground hover:border-primary/50">{item}</span>
            ))}
          </div>
        ))}
      </div>
    </section>
  )}

  {otherNovels.length > 0 && (
    <section aria-labelledby="other-novels-heading">
      <h2 id="other-novels-heading" class="flex items-center gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary text-base font-semibold text-card-foreground">
        Author's Other Novels
      </h2>
      <ul class="list-none p-0 m-0 border border-border rounded-lg overflow-hidden mb-4">
        {otherNovels.map((novel, i) => (
          <li class="border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022]">
            <a href={novel.url} title={novel.title} target="_blank" class="group flex items-center gap-2.5 py-2 px-3.5 text-[13px] font-semibold text-[#2a2a2a] no-underline! transition-colors hover:text-primary dark:text-[#c8ccdc] dark:hover:text-primary">
              <span class="text-[10px] font-bold text-[#ccc] min-w-[14px] text-right shrink-0 leading-none group-hover:text-primary/50 dark:text-white/[0.38] dark:group-hover:text-primary/45">{i + 1}</span>
              {novel.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section aria-labelledby="details-heading">
    <div class="flex items-center justify-between gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary">
      <span id="details-heading" class="flex-1 text-base font-semibold text-card-foreground">Details</span>
      <div class="flex gap-1">
        <button type="button" class="inline-flex cursor-pointer shrink-0 items-center justify-center border border-border bg-card hover:bg-muted hover:text-foreground h-7 gap-1 rounded-lg px-2.5 text-[0.8rem] font-medium whitespace-nowrap transition-all outline-none select-none text-muted-foreground">
          Edit
        </button>
        <button type="button" class="inline-flex cursor-pointer shrink-0 items-center justify-center border border-border bg-card hover:bg-muted hover:text-foreground h-7 gap-1 rounded-lg px-2.5 text-[0.8rem] font-medium whitespace-nowrap transition-all outline-none select-none text-muted-foreground">
          History
        </button>
      </div>
    </div>
    <div class="rounded-lg overflow-hidden border border-border mb-4">
      <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
        <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Titles</span>
        <div class="text-[13px] leading-relaxed wrap-break-word">
          <ul class="m-0 pl-0 list-none">
            {title && <li class="py-px text-[13px]">{title}</li>}
            {chineseTitle && <li class="py-px text-[13px]">{chineseTitle}</li>}
          </ul>
        </div>
      </div>

      <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
        <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Status</span>
        <div class="text-[13px] leading-relaxed wrap-break-word">{details?.status || "Unknown"}</div>
      </div>

      {details?.dateAdded && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Date Added</span>
          <div class="text-[13px] leading-relaxed wrap-break-word">{details.dateAdded}</div>
        </div>
      )}

      {(details?.author || details?.authorPinyin) && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Author</span>
          <div class="text-[13px] leading-relaxed wrap-break-word flex flex-col gap-px">
            {details?.authorUrl ? (
              <a href={details.authorUrl} class="no-underline font-semibold hover:text-primary">{details.author}</a>
            ) : (
              <span>{details?.author}</span>
            )}
            {details?.authorPinyin && <a class="text-xs opacity-65" href={details.authorUrl}>{details.authorPinyin}</a>}
          </div>
        </div>
      )}

      {details?.requested && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Requested</span>
          <div class="text-[13px] leading-relaxed wrap-break-word">
            {details.requestedUrl ? (
              <a href={details.requestedUrl} class="no-underline font-semibold hover:text-primary">{details.requested}</a>
            ) : (
              <span>{details.requested}</span>
            )}
          </div>
        </div>
      )}

      {details?.year && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Year</span>
          <div class="text-[13px] leading-relaxed wrap-break-word">{details.year}</div>
        </div>
      )}

      {details?.origin && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Origin</span>
          <div class="text-[13px] leading-relaxed wrap-break-word">{details.origin}</div>
        </div>
      )}

      {details?.language && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Language</span>
          <div class="text-[13px] leading-relaxed wrap-break-word">{details.language}</div>
        </div>
      )}

      {rankings && (rankings.weekly || rankings.allTime) && (
        <div class="grid grid-cols-[108px_1fr] items-center gap-x-2.5 px-3.5 py-[9px] border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022] max-[400px]:grid-cols-1 max-[400px]:gap-0.5 max-[400px]:px-3 max-[400px]:py-2">
          <span class="text-[10.5px] font-bold uppercase tracking-[0.07em] whitespace-nowrap pt-px leading-6 text-muted-foreground">Rankings</span>
          <div class="text-[13px] leading-relaxed wrap-break-word flex flex-wrap gap-1.5">
            {rankings.weekly && (
              <a class="inline-flex flex-col items-center min-w-[58px] pt-[5px] px-2 pb-1 bg-black/3 border border-border rounded-[7px] no-underline hover:border-primary hover:bg-primary/20 hover:shadow-[0_2px_8px_rgba(253,126,20,0.12)] transition-[border-color,background,box-shadow] duration-200">
                <span class="text-[9px] font-bold uppercase tracking-[0.1em] text-muted-foreground leading-[1.3]">Weekly</span>
                <span class="text-sm font-bold text-foreground leading-[1.4]">#{rankings.weekly}</span>
              </a>
            )}
            {rankings.allTime && (
              <a class="inline-flex flex-col items-center min-w-[58px] pt-[5px] px-2 pb-1 bg-black/3 border border-border rounded-[7px] no-underline hover:border-primary hover:bg-primary/20 hover:shadow-[0_2px_8px_rgba(253,126,20,0.12)] transition-[border-color,background,box-shadow] duration-200">
                <span class="text-[9px] font-bold uppercase tracking-[0.1em] text-muted-foreground leading-[1.3]">All Time</span>
                <span class="text-sm font-bold text-foreground leading-[1.4]">#{rankings.allTime}</span>
              </a>
            )}
          </div>
        </div>
      )}
    </div>
  </section>

  {patrons.length > 0 && (
    <section aria-labelledby="patrons-heading">
      <h2 id="patrons-heading" class="flex items-center gap-2 mt-4 mb-2 pl-2.5 border-l-2 border-l-primary text-base font-semibold text-card-foreground">
        <svg class="icon inline-flex shrink-0 size-4 text-wtr me-1"><use href="#crown"></use></svg>
        Novel Patrons
      </h2>
      <ul class="rounded-lg border border-border overflow-hidden mb-2">
        {patrons.map(patron => (
          <li class="flex items-center justify-between px-3 py-2 text-xs border-b border-border last:border-b-0 even:bg-black/[0.016] dark:even:bg-white/[0.022]">
            <div class="flex items-center gap-2">
              <span
                class="inline-flex items-center justify-center w-5 h-5 rounded text-xs font-bold shrink-0"
                class:list={[
                  patron.rank === 1 ? "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300" : "",
                  patron.rank === 2 ? "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-300" : "",
                  patron.rank === 3 ? "bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300" : "",
                  patron.rank && patron.rank > 3 ? "bg-muted text-muted-foreground" : "",
                ]}
              >
                {patron.rank}
              </span>
              <span class="text-foreground/80">{patron.name}</span>
            </div>
            <span class="text-wtr font-medium">
              <svg class="icon inline-flex shrink-0 size-3 me-0.5"><use href="#ticket"></use></svg>
              {patron.amount}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}
</div>
