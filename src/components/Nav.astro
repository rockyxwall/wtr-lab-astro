---
---

<header class="site-header">
<nav
  class="sticky inset-x-0 top-0 z-40 border-b border-white/10 bg-navbar py-2 text-white shadow-md transition-transform duration-200 [body.hide-navbar:not(.popover-open)_&]:-translate-y-14 font-sans antialiased"
  style="margin-bottom: 8px" translate="no" aria-label="Main navigation"
>
  <div class="mx-auto flex w-full max-w-7xl items-center px-2">
    <button
      type="button" tabindex="0"
      class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none size-10 border-white/30 bg-transparent text-white/85 hover:bg-white/10 hover:text-white focus-visible:border-white/50 focus-visible:bg-white/10 focus-visible:text-white mr-1 ml-0"
    >
      <svg class="icon inline-flex shrink-0 size-6"><use href="#menu"></use></svg>
    </button>

    <div data-closed="" data-swipe-direction="right" role="presentation" aria-hidden="true" data-slot="drawer-swipe-area" class="data-[swipe-direction=right]:inset-y-0 data-[swipe-direction=right]:left-0 data-[swipe-direction=right]:w-10 fixed inset-y-0 left-0 z-50 w-4" style="touch-action: pan-y;"></div>

    <a
      class="me-4 inline-flex items-center gap-2 whitespace-nowrap text-[18px] font-semibold text-white/90 hover:no-underline transition-colors hover:text-white"
      href="https://wtr-lab.com/en"
    >
      <svg class="icon size-[30px] shrink-0" viewBox="0 0 512 512" fill="#fff">
        <path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm0 448c-110.5 0-200-89.5-200-200S145.5 56 256 56s200 89.5 200 200-89.5 200-200 200zm-32-304v192l128-96z"/>
      </svg>
      <span>WTR-LAB</span>
    </a>

    <div class="ml-auto flex lg:hidden">
      <button
        type="button" tabindex="0"
        class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none size-10 border-white/30 bg-transparent text-white/85 hover:bg-white/10 hover:text-white focus-visible:border-white/50 focus-visible:bg-white/10 focus-visible:text-white"
      >
        <svg class="icon inline-flex shrink-0 size-6"><use href="#search"></use></svg>
      </button>
    </div>

    <div class="hidden lg:flex items-center ml-auto gap-1">
      <a href="https://wtr-lab.com/en/library" class="inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm transition-colors hover:text-white/80 hover:no-underline text-white/55">
        <svg class="icon size-4 opacity-55"><use href="#book-marked"></use></svg>
        Library
      </a>
      <a href="https://wtr-lab.com/en/novel-list" class="inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm transition-colors hover:text-white/80 hover:no-underline text-white/55">
        <svg class="icon size-4 opacity-55"><use href="#bookshelf"></use></svg>
        Novels
      </a>
      <a href="https://wtr-lab.com/en/ranking/daily" class="inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm transition-colors hover:text-white/80 hover:no-underline text-white/55">
        <svg class="icon size-4 opacity-55"><use href="#sort-variant-white"></use></svg>
        Ranking
      </a>
      <a href="https://wtr-lab.com/en/leaderboard" class="inline-flex items-center gap-1 rounded-md px-2 py-2 text-sm transition-colors hover:text-white/80 hover:no-underline text-white/55">
        <svg class="icon size-4 opacity-55"><use href="#crown"></use></svg>
        Leaderboard
      </a>
    </div>

    <div class="flex items-center gap-1 ml-2">
      <button
        type="button" tabindex="0"
        class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none size-10 border border-white/30 bg-transparent text-white/85 hover:bg-white/10 hover:text-white focus-visible:border-white/50 focus-visible:bg-white/10 focus-visible:text-white"
      >
        <svg class="icon inline-flex shrink-0 size-5"><use href="#inbox"></use></svg>
      </button>
      <button
        type="button" tabindex="0"
        class="group/button inline-flex cursor-pointer shrink-0 items-center justify-center rounded-lg bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none size-10 border border-white/30 bg-transparent text-white/85 hover:bg-white/10 hover:text-white focus-visible:border-white/50 focus-visible:bg-white/10 focus-visible:text-white"
      >
        <svg class="icon inline-flex shrink-0 size-5"><use href="#profile3"></use></svg>
      </button>
    </div>
  </div>
</nav>
</header>
