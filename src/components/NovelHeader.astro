---
interface Props {
  title?: string;
  chineseTitle?: string;
  cover?: string;
  status?: string;
  views?: string;
  chapters?: number;
  rating?: number;
  readers?: number;
  totalChars?: string;
  tags?: string[];
  genres?: string[];
}

const {
  title = "",
  chineseTitle = "",
  cover = "",
  status = "",
  views = "",
  chapters = 0,
  rating = 0,
  readers = 0,
  totalChars = "",
  tags = [],
  genres = [],
} = Astro.props;

const isMale = genres.some(g => g.toLowerCase() === "male protagonist" || g.toLowerCase() === "male");
const displayGenres = genres.filter(g => g.toLowerCase() !== "male protagonist" && g.toLowerCase() !== "male" && g.toLowerCase() !== "female protagonist" && g.toLowerCase() !== "female");
const headerTagSet = new Set(["male", "cultivation", "business management", "system", "transmigration", "farming", "leadership"]);
const headerTags = tags.filter(t => headerTagSet.has(t.toLowerCase()));
const allHeaderChips = [...displayGenres, ...headerTags].sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
---

<section class="novel-header flex flex-col gap-0 bg-card text-sm text-card-foreground has-[>img:first-child]:pt-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl shadow rounded-md ring-1 ring-foreground/20 mb-2 overflow-hidden">
  <div class="p-2">
    <div class="flex items-center justify-between gap-2 mb-3">
      <div class="flex-1 min-w-0">
        <h1 class="text-base text-card-foreground sm:text-xl font-bold uppercase tracking-wide leading-tight wrap-break-word">{title}</h1>
        {chineseTitle && (
          <p class="text-xs sm:text-sm text-foreground mt-0.5 wrap-break-word">{chineseTitle}</p>
        )}
      </div>
      <div class="shrink-0 flex items-center gap-1">
        <button
          type="button" tabindex="0" aria-label="Report novel"
          class="group/button inline-flex cursor-pointer items-center justify-center bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none border bg-card hover:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 size-8 h-9 w-9 shrink-0 p-0 border-amber-200 text-amber-600 hover:bg-amber-50 rounded-lg self-start"
        >
          <svg class="icon inline-flex shrink-0 size-4"><use href="#alert-outline"></use></svg>
        </button>
      </div>
    </div>

    <div class="flex w-full rounded-lg border bg-card/50 overflow-hidden mb-3">
      <figure class="shrink-0">
        <div class="image-wrap relative rounded-md h-full w-30 sm:w-40 rounded-none zoom group cursor-pointer">
          <div class="absolute inset-0 z-10 flex items-center justify-center bg-black/0 group-hover:bg-black/30 transition-colors duration-200 rounded-md">
            <svg class="icon inline-flex shrink-0 size-8 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-200 drop-shadow-lg"><use href="#zoom_out"></use></svg>
          </div>
          {cover ? (
            <>
              <div class="absolute inset-0 overflow-hidden z-0">
                <img alt="" aria-hidden="true" loading="lazy" class="absolute inset-0 w-full h-full object-cover scale-110 blur-sm opacity-60 pointer-events-none select-none" src={cover} />
              </div>
              <img src={cover} alt={`Cover of ${title}`} class="relative z-[2] w-full h-full object-cover" style="aspect-ratio: 3/4;" />
            </>
          ) : (
            <div class="w-full h-full bg-muted rounded-md flex items-center justify-center text-muted-foreground text-xs" style="aspect-ratio: 3/4;">No Cover</div>
          )}
          <span class="status top-right">
            <svg class="icon inline-flex size-3 me-0.5"><use href="#zoom_out"></use></svg>
          </span>
        </div>
      </figure>
      <div class="flex flex-1 flex-col min-w-0 p-2 gap-2">
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-1.5">
          {status && (
            <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
              <span class="inline-block w-2 h-2 rounded-full"
                class:list={[status.toLowerCase() === "ongoing" ? "bg-green-500" : status.toLowerCase() === "completed" ? "bg-blue-500" : status.toLowerCase() === "hiatus" ? "bg-yellow-500" : "bg-gray-500"]}
              ></span>
              <span class="truncate">{status}</span>
            </div>
          )}
          {views && (
            <div class="flex items-center gap-1 text-xs text-muted-foreground">
              <svg class="icon inline-flex shrink-0 size-3.5"><use href="#eye-fill"></use></svg>
              <span class="truncate">{views}</span>
            </div>
          )}
          {chapters > 0 && (
            <div class="flex items-center gap-1 text-xs text-muted-foreground">
              <svg class="icon inline-flex shrink-0 size-3.5"><use href="#book"></use></svg>
              <span class="truncate">{chapters}</span>
            </div>
          )}
          {rating > 0 && (
            <div class="flex items-center gap-1 text-xs text-muted-foreground">
              <svg class="icon inline-flex shrink-0 size-3.5 text-amber-400"><use href="#star"></use></svg>
              <span class="truncate">{rating.toFixed(1)}</span>
            </div>
          )}
          {readers > 0 && (
            <div class="flex items-center gap-1 text-xs text-muted-foreground">
              <svg class="icon inline-flex shrink-0 size-3.5"><use href="#account-box-outline"></use></svg>
              <span class="truncate">{readers}</span>
            </div>
          )}
          {totalChars && (
            <div class="flex items-center gap-1 text-xs text-muted-foreground">
              <svg class="icon inline-flex shrink-0 size-3.5"><use href="#text_fields"></use></svg>
              <span class="truncate">{totalChars}</span>
            </div>
          )}
        </div>

        <div class="flex flex-col gap-1.5 mt-auto">
          <a
            href="#"
            class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground transition-colors hover:bg-primary/90 w-fit"
          >
            <svg class="icon inline-flex shrink-0 size-4"><use href="#book-open-variant"></use></svg>
            Continue Reading
          </a>
        </div>
      </div>
    </div>

    {allHeaderChips.length > 0 && (
      <ul class="flex flex-wrap items-center gap-1 max-sm:flex-nowrap max-sm:overflow-x-auto pb-1">
        {allHeaderChips.map(c => (
          <li class="inline-flex items-center capitalize text-xs font-medium border rounded px-1.5 py-0.5 whitespace-nowrap transition-colors border-border/70 text-card-foreground">
            {c}
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
